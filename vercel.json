{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "simpletoolbox.dev" }],
      "destination": "https://www.simpletoolbox.dev/:path*",
      "permanent": true
    },
    {
      "source": "/tools/file-size-converter",
      "destination": "/tools/data-storage-converter",
      "permanent": true
    },
    {
      "source": "/tools/file-size-converter.html",
      "destination": "/tools/data-storage-converter",
      "permanent": true
    },
    {
      "source": "/tools/text-case-converter",
      "destination": "/tools/text-case",
      "permanent": true
    },
    {
      "source": "/tools/text-case-converter.html",
      "destination": "/tools/text-case",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)\\.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
